api-key: {{apiKey}}
secret-key: {{secret}}
Content-Type: application/json

{
  "request_id": "{{date}}-TC005",
  "serviceID": "smile-direct",
  "billersCode": "{{phone}}",
  "variation_code": "smile-direct-500",
  "amount": 500,
  "phone": "{{phone}}"
}

