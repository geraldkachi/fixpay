# Dev server — requests use relative /api base so both MSW and the Vite proxy work.
# Mode is controlled at runtime via the DevModeToggle pill on the login screen:
#   'mock' (default) → MSW intercepts; no backend needed
#   'live'           → Vite proxy forwards /api and /tenant to localhost:8081
#
# localStorage key: fixpay_dev_mode  ('mock' | 'live')

# Keycloak (customers realm)
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=customers
VITE_KEYCLOAK_CLIENT_ID=fixpay-pwa
