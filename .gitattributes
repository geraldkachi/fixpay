# Normalise line endings to LF in the repo; check out as-is on all platforms.
# This prevents the "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf

# Keep binary files untouched
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.jar  binary
*.zip  binary
*.p12  binary
*.jks  binary
