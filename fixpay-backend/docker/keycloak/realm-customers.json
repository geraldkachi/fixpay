{
  "realm": "customers",
  "enabled": true,
  "displayName": "FixPay Customer App",
  "accessTokenLifespan": 900,
  "ssoSessionMaxLifespan": 86400,
  "ssoSessionIdleTimeout": 1800,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "failureFactor": 5,
  "passwordPolicy": "length(8) and digits(1) and notUsername",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "roles": {
    "realm": [
      { "name": "CUSTOMER",         "description": "Verified customer with full app access" },
      { "name": "CUSTOMER_LIMITED", "description": "Customer with limited access (pending KYC)" }
    ]
  },
  "clients": [
    {
      "clientId": "fixpay-pwa",
      "name": "FixPay PWA (customer app)",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "redirectUris": [
        "http://localhost:5173/*",
        "https://fixpay-poc.surge.sh/*",
        "https://fixpay.ng/*",
        "https://*.fixpay.ng/*"
      ],
      "webOrigins": ["+"]
    },
    {
      "clientId": "fixpay-core-service",
      "name": "FixPay Core Service Account (creates customers)",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false
    },
    {
      "clientId": "fixpay-gateway-customers",
      "name": "FixPay Gateway (customers realm)",
      "publicClient": false,
      "bearerOnly": true
    }
  ],
  "userProfileConfig": {
    "attributes": [
      { "name": "username",    "displayName": "${username}",   "validations": { "length": { "min": 3, "max": 255 } } },
      { "name": "email",       "displayName": "${email}",      "validations": { "email": {} } },
      { "name": "firstName",   "displayName": "${firstName}" },
      { "name": "lastName",    "displayName": "${lastName}"  },
      {
        "name": "tenant_id",
        "displayName": "Tenant ID",
        "permissions": { "view": ["admin", "user"], "edit": ["admin"] },
        "validations": { "length": { "min": 1, "max": 36 } },
        "annotations": { "inputType": "text" }
      },
      {
        "name": "kyc_status",
        "displayName": "KYC Status",
        "permissions": { "view": ["admin", "user"], "edit": ["admin"] },
        "validations": { "options": { "options": ["pending", "partial", "verified", "rejected"] } }
      },
      {
        "name": "tier",
        "displayName": "Customer Tier",
        "permissions": { "view": ["admin", "user"], "edit": ["admin"] },
        "validations": { "options": { "options": ["1", "2", "3"] } }
      }
    ]
  }
}
