{
  "realm": "tenants",
  "enabled": true,
  "displayName": "FixPay Tenant Portal",
  "accessTokenLifespan": 600,
  "ssoSessionMaxLifespan": 28800,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "failureFactor": 5,
  "passwordPolicy": "length(10) and upperCase(1) and digits(1) and notUsername",
  "roles": {
    "realm": [
      { "name": "TENANT_ADMIN",    "description": "Full tenant administration" },
      { "name": "TENANT_STAFF",    "description": "Day-to-day operations staff" },
      { "name": "TENANT_READONLY", "description": "Read-only access to tenant data" }
    ]
  },
  "clients": [
    {
      "clientId": "fixpay-tenant-portal",
      "name": "FixPay Tenant Portal (SPA)",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "redirectUris": [
        "http://localhost:3001/*",
        "https://portal.fixpay.ng/*"
      ],
      "webOrigins": ["+"]
    },
    {
      "clientId": "fixpay-services-tenants",
      "name": "FixPay M2M Service Account (tenants realm)",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false
    },
    {
      "clientId": "fixpay-gateway-tenants",
      "name": "FixPay Gateway (tenants realm)",
      "publicClient": false,
      "bearerOnly": true
    }
  ]
}
